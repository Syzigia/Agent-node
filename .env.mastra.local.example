# Mastra Studio local filesystem mode
# Copy this file to .env.mastra.local and adjust MASTRA_STUDIO_WORKSPACE_PATH.
# This file is loaded on top of .env/.env.local by `bun run mastra:dev:local`.

MASTRA_STUDIO_LOCAL_FS=1
MASTRA_STUDIO_WORKSPACE_PATH=.mastra/studio-workspace

# Keep Studio memory/storage local and persistent (no cloud DB writes)
DATABASE_URL=file:.mastra/studio-memory.db
DATABASE_TOKEN=
