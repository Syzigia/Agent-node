# Required: OpenRouter API key (used by coordinator, content, and asset agents via minimax/minimax-m2.5)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# Optional: OpenAI API key (if switching back to OpenAI models)
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: ElevenLabs API key (text-to-speech capabilities)
ELEVENLABS_API_KEY=sk_your-elevenlabs-key-here

# Optional: Replicate API key (model inference)
REPLICATE_API_KEY=r8_your-replicate-key-here

# Optional: Hugging Face API token (model inference)
HF_API_TOKEN=hf_your-huggingface-token-here
