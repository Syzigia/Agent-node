# Optional: OpenRouter API key (only needed if you keep using OpenRouter models)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# Required: Azure OpenAI API key for the official AI SDK provider
AZURE_API_KEY=your-azure-openai-api-key-here

# Required unless you prefer a full base URL
AZURE_RESOURCE_NAME=syzygy-llm-model

# Optional: use this instead of AZURE_RESOURCE_NAME when routing through a custom endpoint/proxy
# AZURE_BASE_URL=https://your-resource.openai.azure.com/openai

# Optional: only set this when your Azure deployment requires a non-default API version
# AZURE_API_VERSION=2025-04-01-preview

# Optional: enable legacy deployment-based URLs only when a deployment specifically requires them
# AZURE_USE_DEPLOYMENT_BASED_URLS=false

# Backwards-compatible aliases still supported by the code, but AZURE_* is preferred
# AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
# AZURE_OPENAI_RESOURCE_NAME=syzygy-llm-model
# AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai
# AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Optional: Override deployment names if your Azure deployments use custom names
AZURE_MISTRAL_LARGE_3_DEPLOYMENT=Mistral-Large-3
AZURE_GPT_5_MINI_DEPLOYMENT=gpt-5-mini
AZURE_GPT_5_3_CHAT_DEPLOYMENT=gpt-5.3-chat
AZURE_O4_MINI_DEPLOYMENT=o4-mini
AZURE_GPT_5_NANO_DEPLOYMENT=gpt-5-nano
# Important: do not append inline comments on deployment lines because the full value is used as the deployment name.

# Optional: direct endpoint override for models hosted in a different Azure resource
# Example:
# AZURE_GPT_5_3_CHAT_BASE_URL=https://jorge-mmsmnq3d-eastus2.cognitiveservices.azure.com
# AZURE_GPT_5_3_CHAT_API_KEY=your-api-key-here
# Backwards-compatible aliases also supported:
# AZURE_GPT_5_3_CHAT_ENDPOINT=https://jorge-mmsmnq3d-eastus2.cognitiveservices.azure.com
# AZURE_API_KEY_EASTUS2=your-api-key-here

# Optional: OpenAI API key (still required by workflows that call OpenAI directly)
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: ElevenLabs API key (text-to-speech capabilities)
ELEVENLABS_API_KEY=sk_your-elevenlabs-key-here

# Optional: Replicate API key (model inference)
REPLICATE_API_KEY=r8_your-replicate-key-here

# Optional: Hugging Face API token (model inference)
HF_API_TOKEN=hf_your-huggingface-token-here

# Required: S3-compatible storage (Cloudflare R2, AWS S3, MinIO, etc.)
S3_BUCKET=syzygy
S3_REGION=auto
S3_ENDPOINT=https://729a7ca87f82d70e3f14e2b09fe902a5.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your-s3-access-key-id
S3_SECRET_ACCESS_KEY=your-s3-secret-access-key
# Optional: prefix to scope all operations to a subfolder (e.g., "photos/input")
S3_PREFIX=test
